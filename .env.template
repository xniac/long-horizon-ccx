# Copy to .env and fill in. `.env` is gitignored — never commit a real key.
#   cp .env.template .env   &&   $EDITOR .env

# Required for the real (non-simulated) backend.
ANTHROPIC_API_KEY=sk-ant-...

# --- optional knobs for the real backend (defaults shown) -------------------
# Transport: auto | sdk | cli.
#   auto = use the `claude` CLI if on PATH, else the Python Agent SDK.
#   sdk  = force claude_agent_sdk.query()  (pip install claude-agent-sdk)
#   cli  = force headless `claude -p`
LHX_SDK_TRANSPORT=auto

# Use a cheap, fast model for eval trials (the harness is model-agnostic).
LHX_SDK_MODEL=claude-haiku-4-5-20251001
LHX_SDK_MAX_TURNS=80
LHX_SDK_TIMEOUT=900
